            </NavLink>
            <NavLink class="nav-link" href="admin/audit/api">
                <span class="nav-icon">🌐</span><span>API calls</span>
            </NavLink>
            <NavLink class="nav-link" href="admin/audit/downloader">
                <span class="nav-icon">📥</span><span>Downloader</span>
            </NavLink>
            <NavLink class="nav-link" href="admin/audit/website">
                <span class="nav-icon">🖥️</span><span>Website</span>
            </NavLink>
            <NavLink class="nav-link" href="admin/audit/errors">
                <span class="nav-icon">⚠️</span><span>Errors</span>
            </NavLink>
            <NavLink class="nav-link" href="admin/audit/schema">
                <span class="nav-icon">🧱</span><span>Schema</span>
            </NavLink>
