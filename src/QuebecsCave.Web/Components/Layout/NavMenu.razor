    </NavLink>

    <NavLink class="nav-link" href="streams">
        <img class="nav-emoji" src="emojis/quebDig.png" alt="" />
        <span>Streams</span>
    </NavLink>

    <NavLink class="nav-link" href="games">
        <img class="nav-emoji" src="emojis/quebKing.png" alt="" />
        <span>Games</span>
    </NavLink>

    <AuthorizeView Policy="@AuthorizationPolicies.AuditAccess">
        <Authorized>
            <div class="nav-section">Audit history</div>
            <NavLink class="nav-link" href="admin/audit">
                <img class="nav-emoji" src="emojis/quebRaid.png" alt="" />
