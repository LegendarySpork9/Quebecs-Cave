@page "/admin/audit/downloader"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using QuebecsCave.Core.Audit
@using QuebecsCave.Web.Auth
@attribute [Authorize(Policy = AuthorizationPolicies.AuditAccess)]
@inject IDownloaderEventQueryRepository Repo

<PageTitle>Downloader audit · Quebec's Cave</PageTitle>

<header class="page-head">
    <h1>Downloader audit</h1>
    <p class="muted">Each stage the console downloader has stepped through.</p>
</header>

<div class="card filter-bar">
    <div class="filter">
        <label>Stage</label>
        <select @bind="_stage" @bind:after="OnFilterChanged">
            <option value="">Any</option>
            <option>Poll</option><option>TwitchAuth</option><option>TwitchVodList</option>
            <option>Download</option><option>Upload</option><option>Ingest</option><option>Heartbeat</option>
        </select>
    </div>
    <div class="filter">
        <label>Outcome</label>
        <select @bind="_success" @bind:after="OnFilterChanged">
            <option value="">Any</option>
            <option value="true">Success</option>
            <option value="false">Failure</option>
        </select>
    </div>
    <div class="filter grow">
        <label>VOD ID</label>
        <input type="search" placeholder="2760085764…" @bind="_vodId" @bind:event="oninput" @bind:after="OnSearchTyped" />
    </div>
    <div class="filter">
        <label>From</label>
        <input type="date" @bind="_from" @bind:after="OnFilterChanged" />
    </div>
    <div class="filter">
        <label>To</label>
        <input type="date" @bind="_to" @bind:after="OnFilterChanged" />
    </div>
</div>

@if (_loading) { <p class="muted">Loading…</p> }
else
{
    <p class="muted small results-count">@_page.Total event(s)</p>
    <div class="card audit-table-wrap">
        <table class="audit-table">
            <thead><tr><th>When</th><th>Stage</th><th>VOD</th><th>OK</th><th>Dur</th><th>Message</th></tr></thead>
            <tbody>
            @foreach (var row in _page.Items)
            {
                <tr class="@(row.Success ? "" : "row-warn")">
                    <td><time>@row.OccurredAt.ToLocalTime().ToString("dd MMM HH:mm:ss")</time></td>
                    <td>@row.Stage</td>
                    <td>@(row.TwitchVodId ?? "—")</td>
                    <td>@(row.Success ? "✓" : "✗")</td>
                    <td>@(row.DurationMs?.ToString() ?? "—")</td>
                    <td class="message-cell">@(row.Message ?? "")</td>
                </tr>
            }
            @if (_page.Items.Count == 0) { <tr><td colspan="6" class="muted center">No matches.</td></tr> }
            </tbody>
        </table>
    </div>
    @if (_page.Total > _take)
    {
        <nav class="pager">
            <button class="btn btn-ghost" @onclick="PrevPage" disabled="@(_skip == 0)">← Newer</button>
            <span class="muted small">Page @((_skip / _take) + 1)</span>
            <button class="btn btn-ghost" @onclick="NextPage" disabled="@(_skip + _take >= _page.Total)">Older →</button>
        </nav>
    }
}

@code {
    private const int _take = 25;
    private AuditPage<DownloaderEventRow> _page = new(Array.Empty<DownloaderEventRow>(), 0, 0, _take);
    private bool _loading = true;
    private int _skip;
    private string? _stage, _success, _vodId;
    private DateTime? _from, _to;
    private CancellationTokenSource? _searchCts;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try
        {
            bool? success = _success == "true" ? true : _success == "false" ? false : null;
            var filter = new DownloaderEventFilter(
                _from.HasValue ? new DateTimeOffset(_from.Value, TimeSpan.Zero) : null,
                _to.HasValue ? new DateTimeOffset(_to.Value.AddDays(1), TimeSpan.Zero) : null,
                string.IsNullOrEmpty(_stage) ? null : _stage,
                success,
                string.IsNullOrWhiteSpace(_vodId) ? null : _vodId.Trim(),
                _skip, _take);
            _page = await Repo.SearchAsync(filter, CancellationToken.None);
        }
        catch
        {
            _page = new AuditPage<DownloaderEventRow>(Array.Empty<DownloaderEventRow>(), 0, _skip, _take);
        }
        _loading = false;
    }

    private async Task OnFilterChanged() { _skip = 0; await LoadAsync(); }
    private async Task OnSearchTyped()
    {
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        try { await Task.Delay(280, _searchCts.Token); _skip = 0; await LoadAsync(); } catch (TaskCanceledException) { }
    }
    private async Task PrevPage() { if (_skip > 0) { _skip -= _take; await LoadAsync(); } }
    private async Task NextPage() { if (_skip + _take < _page.Total) { _skip += _take; await LoadAsync(); } }
}
