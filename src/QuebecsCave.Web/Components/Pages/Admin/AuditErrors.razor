@page "/admin/audit/errors"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using QuebecsCave.Core.Audit
@using QuebecsCave.Core.Domain
@using QuebecsCave.Web.Auth
@attribute [Authorize(Policy = AuthorizationPolicies.AuditAccess)]
@inject IErrorLogQueryRepository Repo
@inject IErrorStatusLookup StatusLookup
@inject QuebecsCave.Core.Time.IClock Clock

<PageTitle>Error log · Quebec's Cave</PageTitle>

<header class="page-head">
    <h1>Errors</h1>
    <p class="muted">
        Unhandled exceptions across API, website, downloader, and background services.
        Acknowledge, link to a manually-created GitHub issue, and mark fixed when sorted.
    </p>
</header>

<div class="card filter-bar">
    <div class="filter">
        <label>Source</label>
        <select @bind="_source" @bind:after="OnFilterChanged">
            <option value="">Any</option>
            <option>Api</option><option>Website</option><option>Downloader</option><option>BackgroundService</option>
        </select>
    </div>
    <div class="filter">
        <label>Status</label>
        <select @bind="_status" @bind:after="OnFilterChanged">
            <option value="">Any</option>
            <option>Open</option><option>Acknowledged</option><option>RaisedToGit</option>
            <option>Fixed</option><option>NonIssue</option>
        </select>
    </div>
    <div class="filter grow">
        <label>Search (message / stack)</label>
        <input type="search" @bind="_search" @bind:event="oninput" @bind:after="OnSearchTyped" />
    </div>
    <div class="filter">
        <label>From</label>
        <input type="date" @bind="_from" @bind:after="OnFilterChanged" />
    </div>
    <div class="filter">
        <label>To</label>
        <input type="date" @bind="_to" @bind:after="OnFilterChanged" />
    </div>
</div>

@if (_loading) { <p class="muted">Loading…</p> }
else
{
    <p class="muted small results-count">@_page.Total error(s)</p>
    <div class="card audit-table-wrap">
        <table class="audit-table">
            <thead><tr><th>When</th><th>Source</th><th>Type</th><th>Message</th><th>Status</th><th></th></tr></thead>
            <tbody>
            @foreach (var row in _page.Items)
            {
                <tr class="@StatusRowClass(row.StatusName)">
                    <td><time>@row.OccurredAt.ToLocalTime().ToString("dd MMM HH:mm")</time></td>
                    <td>@row.Source</td>
                    <td><code>@ShortType(row.ExceptionType)</code></td>
                    <td class="message-cell">@row.Message</td>
                    <td><span class="status-pill status-@row.StatusName.ToLowerInvariant()">@row.StatusName</span></td>
                    <td><button class="btn btn-ghost btn-tiny" @onclick="() => OpenDrawer(row)">Open</button></td>
                </tr>
            }
            @if (_page.Items.Count == 0) { <tr><td colspan="6" class="muted center">Nothing on fire. 🎉</td></tr> }
            </tbody>
        </table>
    </div>
    @if (_page.Total > _take)
    {
        <nav class="pager">
            <button class="btn btn-ghost" @onclick="PrevPage" disabled="@(_skip == 0)">← Newer</button>
            <span class="muted small">Page @((_skip / _take) + 1)</span>
            <button class="btn btn-ghost" @onclick="NextPage" disabled="@(_skip + _take >= _page.Total)">Older →</button>
        </nav>
    }
}

@if (_drawerRow is not null)
{
    <div class="drawer-overlay" @onclick="CloseDrawer">
        <div class="drawer card" @onclick:stopPropagation="true">
            <header class="drawer-head">
                <div>
                    <h3>@ShortType(_drawerRow.ExceptionType)</h3>
                    <p class="muted small">
                        @_drawerRow.OccurredAt.ToLocalTime().ToString("dd MMM yyyy HH:mm:ss") · @_drawerRow.Source
                    </p>
                </div>
                <button class="btn-icon" @onclick="CloseDrawer" title="Close">✕</button>
            </header>

            <div class="drawer-body">
                <h4>Message</h4>
                <pre class="error-message">@_drawerRow.Message</pre>

                @if (!string.IsNullOrEmpty(_drawerRow.Context))
                {
                    <h4>Context</h4>
                    <pre class="error-context">@_drawerRow.Context</pre>
                }

                @if (!string.IsNullOrEmpty(_drawerRow.StackTrace))
                {
                    <h4>Stack trace</h4>
                    <pre class="error-stack">@_drawerRow.StackTrace</pre>
                }

                <h4>Workflow</h4>
                <p class="small">
                    Status: <strong>@_drawerRow.StatusName</strong>
                    @if (_drawerRow.AddressedAt.HasValue)
                    {
                        <text> · last touched </text>
                        <time>@_drawerRow.AddressedAt.Value.ToLocalTime().ToString("dd MMM HH:mm")</time>
                        @if (!string.IsNullOrEmpty(_drawerRow.AddressedByLogin))
                        {
                            <text> by @_drawerRow.AddressedByLogin</text>
                        }
                    }
                </p>

                @if (!string.IsNullOrEmpty(_drawerRow.GitHubIssueUrl))
                {
                    <p class="small">
                        🔗 <a href="@_drawerRow.GitHubIssueUrl" target="_blank" rel="noopener">@_drawerRow.GitHubIssueUrl</a>
                    </p>
                }

                @if (!string.IsNullOrEmpty(_drawerRow.Notes))
                {
                    <h4>Notes</h4>
                    <pre class="error-notes">@_drawerRow.Notes</pre>
                }

                <div class="workflow-actions">
                    <button class="btn btn-ghost" @onclick="() => SetStatusAsync(ErrorStatusName.Acknowledged)">Acknowledge</button>
                    <button class="btn btn-ghost" @onclick="OpenGitHubModal">Raise to GitHub…</button>
                    <button class="btn btn-primary" @onclick="() => SetStatusAsync(ErrorStatusName.Fixed)">Mark fixed</button>
                    <button class="btn btn-ghost" @onclick="() => SetStatusAsync(ErrorStatusName.NonIssue)">Mark non-issue</button>
                </div>

                <div class="notes-edit">
                    <label>Add a note (saved with the next status change)</label>
                    <textarea rows="3" @bind="_pendingNotes" placeholder="What did you find? What's the plan?"></textarea>
                </div>
            </div>
        </div>
    </div>
}

@if (_githubModal)
{
    <div class="drawer-overlay" @onclick="CloseGitHubModal">
        <div class="modal card" @onclick:stopPropagation="true">
            <h3>Raise to GitHub</h3>
            <p class="muted small">
                Create the issue manually in GitHub, then paste the issue URL here.
                The status switches to <strong>RaisedToGit</strong>.
            </p>
            <input type="url" placeholder="https://github.com/…/issues/123" @bind="_githubUrl" class="github-url" />
            <div class="modal-actions">
                <button class="btn btn-ghost" @onclick="CloseGitHubModal">Cancel</button>
                <button class="btn btn-primary"
                        @onclick="() => SetStatusAsync(ErrorStatusName.RaisedToGit, _githubUrl)"
                        disabled="@(string.IsNullOrWhiteSpace(_githubUrl))">
                    Save URL + mark raised
                </button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private const int _take = 25;
    private AuditPage<ErrorLogRow> _page = new(Array.Empty<ErrorLogRow>(), 0, 0, _take);
    private bool _loading = true;
    private int _skip;
    private string? _source, _status, _search;
    private DateTime? _from, _to;
    private CancellationTokenSource? _searchCts;

    private ErrorLogRow? _drawerRow;
    private bool _githubModal;
    private string? _githubUrl;
    private string? _pendingNotes;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try
        {
            int? statusId = null;
            if (!string.IsNullOrEmpty(_status))
            {
                statusId = await StatusLookup.GetIdAsync(_status, CancellationToken.None);
            }

            var filter = new ErrorLogFilter(
                _from.HasValue ? new DateTimeOffset(_from.Value, TimeSpan.Zero) : null,
                _to.HasValue ? new DateTimeOffset(_to.Value.AddDays(1), TimeSpan.Zero) : null,
                string.IsNullOrEmpty(_source) ? null : _source,
                statusId,
                null,
                string.IsNullOrWhiteSpace(_search) ? null : _search.Trim(),
                _skip, _take);
            _page = await Repo.SearchAsync(filter, CancellationToken.None);
        }
        catch
        {
            _page = new AuditPage<ErrorLogRow>(Array.Empty<ErrorLogRow>(), 0, _skip, _take);
        }
        _loading = false;
    }

    private async Task OnFilterChanged() { _skip = 0; await LoadAsync(); }
    private async Task OnSearchTyped()
    {
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        try { await Task.Delay(280, _searchCts.Token); _skip = 0; await LoadAsync(); } catch (TaskCanceledException) { }
    }
    private async Task PrevPage() { if (_skip > 0) { _skip -= _take; await LoadAsync(); } }
    private async Task NextPage() { if (_skip + _take < _page.Total) { _skip += _take; await LoadAsync(); } }

    private void OpenDrawer(ErrorLogRow row)
    {
        _drawerRow = row;
        _pendingNotes = null;
    }
    private void CloseDrawer()
    {
        _drawerRow = null;
        _githubModal = false;
        _githubUrl = null;
    }

    private void OpenGitHubModal() => _githubModal = true;
    private void CloseGitHubModal() { _githubModal = false; _githubUrl = null; }

    private async Task SetStatusAsync(string statusName, string? githubUrl = null)
    {
        if (_drawerRow is null) return;
        try
        {
            var statusId = await StatusLookup.GetIdAsync(statusName, CancellationToken.None);
            int? userId = null;
            if (AuthState is not null)
            {
                var state = await AuthState;
                if (int.TryParse(state.User.FindFirst("user_id")?.Value, out var uid)) userId = uid;
            }
            await Repo.UpdateStatusAsync(
                _drawerRow.ErrorLogId, statusId,
                githubUrl, _pendingNotes, userId, Clock.Now,
                CancellationToken.None);
            CloseDrawer();
            await LoadAsync();
        }
        catch { /* swallow; user can retry */ }
    }

    private static string ShortType(string fullName)
    {
        var dot = fullName.LastIndexOf('.');
        return dot < 0 ? fullName : fullName.Substring(dot + 1);
    }

    private static string StatusRowClass(string statusName) => statusName switch
    {
        "Fixed" or "NonIssue" => "row-resolved",
        "Open" => "row-open",
        _ => "",
    };
}
