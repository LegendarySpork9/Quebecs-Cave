@page "/Error"
@using System.Diagnostics

<PageTitle>Error · Quebec's Cave</PageTitle>

<div class="error-page">
    <img src="emojis/quebBorked.png" alt="" width="120" height="120" />
    <h1>Something broke in the cave</h1>
    <p class="muted">
        An error occurred while processing your request. The error has been logged
        and someone will take a look.
    </p>

    @if (!string.IsNullOrEmpty(RequestId))
    {
        <p class="faint small">
            Request ID: <code>@RequestId</code>
        </p>
    }

    <a class="btn btn-primary" href="/">Back to home</a>
</div>

<style>
    .error-page {
        text-align: center;
        max-width: 520px;
        margin: 4rem auto;
    }
    .error-page img {
        margin-bottom: 1rem;
        filter: drop-shadow(0 4px 12px rgba(0,0,0,0.3));
    }
    .error-page h1 { margin-bottom: 0.75rem; }
    .error-page p { margin-bottom: 1rem; }
    .small { font-size: 0.85rem; }
</style>

@code {
    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
